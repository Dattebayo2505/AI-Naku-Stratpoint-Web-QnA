LCX_ROOT_USERNAME=
LCX_ROOT_PASSWORD=
NON_ROOT_USERNAME=
NON_ROOT_PASSWORD=
# Host + the 2 ports the group is allotted on the LXC (bare-metal run: 1 for the API/BE, 1 for the UI/FE)
PUBLIC_IP_ADDRESS=
PORT=

# RAG — retrieval (defaults in stratpoint_rag/rag/config.py; blank = use default)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
CHROMA_DIR=
CHROMA_COLLECTION=

# RAG — generation LLM (NVIDIA-hosted NIM, OpenAI-compatible chat/completions)
LLM_MODEL=
NVIDIA_BASE_URL=
NVIDIA_API_KEY=

# UI — base URL of the API (blank = http://localhost:8000; docker-compose sets http://api:8000)
STRATPOINT_API_URL=